# dotNOVI Application Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# For development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/dotnovi

# For Docker/production:
# DATABASE_URL=postgresql://postgres:postgrespassword@postgres:5432/dotnovi

# Example PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:port/database

# If DATABASE_URL is not set, the app will start but database operations will fail
